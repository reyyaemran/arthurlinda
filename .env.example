# PostgreSQL (required) — e.g. Neon
# DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# JWT session signing — at least 32 characters: openssl rand -hex 32
AUTH_SECRET=""

# Public invitation slug (must match the wedding row created at first admin signup).
# Defaults to "arthur-linda" if unset.
# NEXT_PUBLIC_WEDDING_SLUG="arthur-linda"
# DEFAULT_WEDDING_SLUG="arthur-linda"

# Optional: real emails via Resend (https://resend.com). If unset in development,
# OTP codes are printed to the server console.
RESEND_API_KEY=""
EMAIL_FROM="Wedding Admin <onboarding@resend.dev>"
